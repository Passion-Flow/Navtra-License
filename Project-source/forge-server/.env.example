# Forge forge-server — local dev defaults. Copy to .env. NEVER commit a real .env.
# Field-ized (no connection strings). Ports follow segment 1 (10000-19999).

APP_ROLE=api                 # api | edge | worker | scheduler
APP_ENV=development
APP_DEBUG=true
APP_PORT=13001
APP_BASE_URL=http://localhost:13000
APP_EDGE_BASE_URL=http://localhost:13002

DEFAULT_LANG=zh-CN
SUPPORTED_LANGS=zh-CN,en

# ---- Database (the type support: postgres, mysql, oracle, tidb) ----
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=15432
DATABASE_USERNAME=forge_app
DATABASE_PASSWORD=change-me
DATABASE_NAME=forge_main
DATABASE_SSL_MODE=prefer

# ---- Cache / Redis ----
CACHE_TYPE=redis
CACHE_HOST=localhost
CACHE_PORT=16379
CACHE_PASSWORD=change-me

# ---- Object Storage (the type support: local, s3, azure-blob, aliyun-oss, ...) ----
OBJECT_STORAGE_TYPE=local
OBJECT_STORAGE_LOCAL_MODE=filesystem
OBJECT_STORAGE_LOCAL_PATH=/var/lib/forge/uploads

# ---- Email (the type support: smtp, aws_ses, sendgrid, aliyun_dm, ...) ----
EMAIL_TYPE=smtp
EMAIL_HOST=localhost
EMAIL_PORT=11025
EMAIL_FROM_ADDRESS=forge@navtra.ai

# ---- Field-level encryption KEK (REQUIRED for api role; base64 of 32 bytes). ----
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
FORGE_FIELD_ENCRYPTION_KEY=#REPLACE_ME#

# ---- Edge / online validation ----
LEASE_TTL_SECONDS=86400
LEASE_GRACE_SECONDS=259200
EDGE_INTERNAL_API_URL=http://localhost:13001
EDGE_INTERNAL_TOKEN=#REPLACE_ME#
