# ==================================================================================================
# Forge — environment file (copy to .env, fill every #REPLACE_ME#). NEVER commit .env.
# Style mirrors Dify's .env.example: sectioned, every value documented, secure-by-default.
# The app FAILS CLOSED in production if a KEK is missing/invalid.
# ==================================================================================================

# --------------------------------------------------------------------------------------------------
# Image / registry
# --------------------------------------------------------------------------------------------------
REGISTRY=crpi-ew8juv9423tvogc4.cn-hongkong.personal.cr.aliyuncs.com/navtra-mirror
FORGE_TAG=v1.0.0

# --------------------------------------------------------------------------------------------------
# Common
# --------------------------------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
# Public base URL of the admin console (used for the CORS whitelist).
APP_BASE_URL=https://forge.example.com
# Public base URL of the edge (license validation endpoint).
EDGE_BASE_URL=https://edge.forge.example.com
TZ=UTC
LOG_LEVEL=INFO
LOG_OUTPUT_FORMAT=json
# Run alembic migrations on api startup before serving.
MIGRATION_ENABLED=true

# Session cookie Secure flag. Keep FALSE for a plain-HTTP trial (default below) — otherwise the
# browser drops the login cookie over HTTP and you can never stay signed in. Set TRUE once you serve
# the console over HTTPS.
SESSION_COOKIE_SECURE=false

# Published ports on the host.
WEB_PORT=80
EDGE_PORT=8081

# --------------------------------------------------------------------------------------------------
# Private CA (optional)
# Trust a self-signed / private-CA https certificate on your DB / object storage / mail endpoints.
# Set to the host path of your CA bundle (PEM). Leave EMPTY to use only the system CAs.
# --------------------------------------------------------------------------------------------------
FORGE_CA_FILE=

# --------------------------------------------------------------------------------------------------
# Field-encryption KEKs  (base64 of 32 random bytes each — generate: openssl rand -base64 32)
# SECURITY: master and edge KEK MUST differ. forge-edge gets ONLY the edge KEK, so a breached edge
# can never decrypt the master signing key.
# --------------------------------------------------------------------------------------------------
FORGE_FIELD_ENCRYPTION_KEY=#REPLACE_ME#
FORGE_EDGE_KEK=#REPLACE_ME#
# Internal service token (edge -> api), 32+ random chars.
EDGE_INTERNAL_TOKEN=#REPLACE_ME#

# --------------------------------------------------------------------------------------------------
# Database
#   DATABASE_TYPE: postgres | mysql | tidb | dameng | opengauss | kingbase | oceanbase
#                  | polardb-pg | polardb-x
#   Bundled DB via profile: --profile postgresql | mysql | dameng. Else point DATABASE_HOST at an
#   external/managed/信创 DB and start no DB profile.
# --------------------------------------------------------------------------------------------------
DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=forge_main
DATABASE_SSL_MODE=prefer
# Full-privilege business account (api/worker/scheduler).
DATABASE_USERNAME=forge_app
DATABASE_PASSWORD=#REPLACE_ME#
# Restricted account for forge-edge (cannot read the master key ciphertext; created by ./init).
EDGE_DATABASE_USERNAME=forge_edge
EDGE_DATABASE_PASSWORD=#REPLACE_ME#

# 达梦 DM8 (信创): set DATABASE_TYPE=dameng, DATABASE_PORT=5236, and provide a DM image whose
# forge-api variant bundles the DM native client libs. DAMENG_IMAGE is the bundled-DB image (optional).
DAMENG_IMAGE=

# --------------------------------------------------------------------------------------------------
# Cache  (CACHE_TYPE: redis | valkey)
# --------------------------------------------------------------------------------------------------
CACHE_TYPE=redis
CACHE_HOST=redis
CACHE_PORT=6379
CACHE_PASSWORD=#REPLACE_ME#

# --------------------------------------------------------------------------------------------------
# Celery
# --------------------------------------------------------------------------------------------------
CELERY_QUEUES=email,default

# --------------------------------------------------------------------------------------------------
# Object storage (license artifacts + CRL)
#   OBJECT_STORAGE_TYPE: local | s3 | aliyun-oss | tencent-cos | volcengine-tos | huawei-obs
#                        | azure-blob | google-storage
#   local => stored on the api volume. For self-hosted S3 start --profile seaweedfs and set
#   OBJECT_STORAGE_TYPE=s3, OBJECT_STORAGE_ENDPOINT=http://seaweedfs:8333.
# --------------------------------------------------------------------------------------------------
OBJECT_STORAGE_TYPE=local
OBJECT_STORAGE_BUCKET=forge
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_SECURE=true

# --------------------------------------------------------------------------------------------------
# Email (expiry reminders)
#   EMAIL_TYPE: smtp | aws_ses | sendgrid | aliyun_dm | tencent_ses | volcengine_dm
#   smtp covers 信创/enterprise mail (Coremail etc.); 465/994 implicit TLS or STARTTLS.
# --------------------------------------------------------------------------------------------------
EMAIL_TYPE=smtp
EMAIL_FROM_ADDRESS=forge@navtra.ai
EMAIL_FROM_NAME=Forge
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USE_TLS=true
# Cloud-email API key (aws_ses/sendgrid/...): used instead of EMAIL_PASSWORD depending on EMAIL_TYPE.
EMAIL_API_KEY=

# --------------------------------------------------------------------------------------------------
# Search (optional)
#   SEARCH_TYPE: opensearch | elasticsearch | transwarp | easysearch | huawei-css | aliyun-es
#                | tencent-es. Start --profile search for a bundled OpenSearch.
# --------------------------------------------------------------------------------------------------
SEARCH_ENABLED=false
SEARCH_TYPE=opensearch
SEARCH_HOST=opensearch
SEARCH_PORT=9200
SEARCH_USERNAME=
SEARCH_PASSWORD=
SEARCH_USE_SSL=false
SEARCH_INDEX_PREFIX=forge
